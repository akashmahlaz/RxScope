# Environment variables — copy to .env and fill in real values
# NEVER commit .env to git

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql://postgres:password@localhost:5432/rxscope
DATABASE_POOL_SIZE=10

# === MiniMax (Anthropic-compatible API) ===
MINIMAX_API_KEY=sk-api-xxxxx
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# === Redis (Upstash or local) ===
REDIS_URL=redis://localhost:6379/0

# === LangSmith Observability ===
LANGSMITH_API_KEY=lsv2_xxxxx
LANGSMITH_PROJECT=rxscope
LANGSMITH_TRACING=true

# === Medical APIs (all free) ===
UMLS_API_KEY=xxxxx
NPI_API_BASE=https://npiregistry.cms.hhs.gov/api
RXNORM_API_BASE=https://rxnav.nlm.nih.gov/REST
OPENFDA_API_BASE=https://api.fda.gov

# === Scraping ===
LIGHTPANDA_WS=ws://127.0.0.1:9222
PROXY_URL=
SCRAPE_RATE_LIMIT=2.0
SCRAPE_USER_AGENT=RxScopeBot/1.0 (+https://rxnetwork.com/bot)

# === Cloudflare ===
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=rxscope-content

# === Application ===
LOG_LEVEL=INFO
CONFIDENCE_AUTO_APPROVE=0.80
CONFIDENCE_OPUS_REVIEW=0.60
EXPORT_FORMAT=xlsx
